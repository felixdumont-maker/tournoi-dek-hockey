# ═══════════════════════════════════════════
# TOURNOI — Variables d'environnement
# ═══════════════════════════════════════════

# MariaDB (ton instance existante)
DB_HOST=mariadb           # Nom du container MariaDB existant
DB_PORT=3306
DB_USER=tournoi
DB_PASSWORD=CHANGE_ME
DB_NAME=tournoi

# Admin
ADMIN_PASSWORD=CHANGE_ME  # Mot de passe pour accéder à /admin

# JWT
SECRET_KEY=CHANGE_ME_RANDOM_STRING_64_CHARS

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@cocktailmedia.ca
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_NAME=Cocktail Media — Tournois
SMTP_FROM_EMAIL=info@cocktailmedia.ca

# Redis (WebSocket broker)
REDIS_URL=redis://redis:6379

# Base URL
BASE_URL=https://tournoi.cocktailmedia.ca
